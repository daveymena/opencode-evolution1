# ==========================================
# 1. CONFIGURACION DEL SERVIDOR
# ==========================================
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ==========================================
# 2. BASE DE DATOS Y MEMORIA AI (SUPABASE o PostgreSQL)
# ==========================================
# Opción 1: Supabase (Remoto - Producción)
DATABASE_URL=postgresql://postgres:password@host:5432/postgres
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Opción 2: PostgreSQL Local/Docker
# DATABASE_URL=postgresql://opencode:opencode@localhost:5432/opencode_evolved
# DATABASE_URL=postgresql://opencode:opencode@db:5432/opencode_evolved

# ==========================================
# 3. INTELIGENCIA ARTIFICIAL
# ==========================================
# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://generativelanguage.googleapis.com/v1alpha/
ANTHROPIC_MODEL=gemini-1.5-pro-latest

# Google
GOOGLE_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Groq
GROQ_API_KEY=

# Otros
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# ==========================================
# 4. INTEGRACIONES - MCP (Model Context Protocol)
# ==========================================
# Dropi Agent (Chatbot)
DROPI_AGENT_TOKEN=

# ==========================================
# 5. PASARELAS DE PAGO
# ==========================================
# MercadoPago (Colombia)
MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_CLIENT_ID=
MERCADOPAGO_ACCESS_TOKEN=

# PayPal (Internacional)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=live
PAYPAL_API_URL=https://api-m.paypal.com

# ==========================================
# 6. GIT INTEGRATION
# ==========================================
GIT_USER_NAME=OpenCode Bot
GIT_USER_EMAIL=daveymena@opencode.ai
GIT_REPO_URL=https://github.com/daveymena/opencode-evolution.git
GIT_TOKEN=
GIT_BRANCH=main

# ==========================================
# 7. API SERVER CONFIGURATION
# ==========================================
API_URL=http://localhost:3001
API_PORT=3001
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ==========================================
# 8. DEVELOPMENT SETTINGS
# ==========================================
DEBUG=false

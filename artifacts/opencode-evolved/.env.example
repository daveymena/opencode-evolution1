# ============================================
# FRONTEND ENVIRONMENT CONFIGURATION
# ============================================

# API URL - Cambia según el entorno
# Para desarrollo local (API en puerto 3001):
# VITE_API_URL=http://localhost:3001

# Para Docker (el proxy en docker-serve.mjs maneja /api):
# VITE_API_URL=/api

# Para producción en EasyPanel:
# VITE_API_URL=https://api.tudominio.com

# Si no está definido, el frontend usa "/api" por defecto

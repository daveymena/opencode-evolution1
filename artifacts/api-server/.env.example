# ============================================
# API SERVER ENVIRONMENT CONFIGURATION
# ============================================

# Server Configuration
NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# Database Configuration
# Para desarrollo local:
# DATABASE_URL=postgresql://opencode:opencode@localhost:5432/opencode_evolved
# Para Docker:
# DATABASE_URL=postgresql://opencode:opencode@db:5432/opencode_evolved

DATABASE_URL=

# CORS Settings
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ============================================
# OPENCODE AI INTEGRATION (Optional)
# ============================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# ============================================
# GIT INTEGRATION (Optional)
# ============================================
GIT_USER_NAME=OpenCode Bot
GIT_USER_EMAIL=opencode@localhost
GIT_REPO_URL=
GIT_TOKEN=
GIT_BRANCH=main

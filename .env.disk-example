# ============================================================
# OpenCode Evolution - Configuración para EasyPanel (DISCO)
# Usa GB de almacenamiento en lugar de RAM
# ============================================================

# ============ BASE DE DATOS (REQUERIDO) ============
# Formato: postgresql://usuario:password@host:puerto/db
DATABASE_URL=postgresql://user:password@db:5432/opencode

# ============ APIS - OBTÉN ESTAS GRATIS ============
# Groq (recomendado, muy rápido): https://console.groq.com
GROQ_API_KEY=

# OpenRouter (acceso múltiples modelos): https://openrouter.ai
OPENROUTER_API_KEY=

# Cerebras (modelos propios): https://cerebras.ai
CEREBRAS_API_KEY=

# ============ APIS DE PAGO (OPCIONAL) ============
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# ============ SUPABASE (OPCIONAL) ============
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# CONFIGURACIÓN DE RUTAS EN DISCO (MUY IMPORTANTE)
# ============================================================
# Estos directorios deben existir en tu servidor y persistirán
# aunque el contenedor se reinicie

# Workspace: Aquí se guardan los proyectos del usuario
# Recomendado: 10-20GB de espacio disponible
WORKSPACE_PATH=/opt/easypanel/opencode/workspace

# Cache: npm, pnpm y otras cachés
# Recomendado: 2-5GB
CACHE_PATH=/opt/easypanel/opencode/cache

# Data: Configuraciones, logs, datos persistentes
# Recomendado: 1-2GB
DATA_PATH=/opt/easypanel/opencode/data

# ============================================================
# CONFIGURACIÓN DE RECURSOS (BAJA RAM, ALTO SWAP)
# ============================================================

# RAM máxima que puede usar el contenedor
# Dejar bajo (1G) porque usaremos swap
MEMORY_LIMIT=1G

# RAM garantizada (reservada)
MEMORY_RESERVATION=256M

# CPUs
CPU_LIMIT=1
CPU_RESERVATION=0.5

# ============================================================
# CONFIGURACIÓN DE NODE.JS (USAR DISCO)
# ============================================================
# Estas variables se configuran automáticamente en el docker-compose
# No necesitas cambiarlas aquí, son para referencia:
#
# NODE_OPTIONS=--max-old-space-size=512 --max-semi-space-size=32 --optimize-for-size
# NPM_CONFIG_CACHE=/cache/npm
# PNPM_HOME=/cache/pnpm
# UV_THREADPOOL_SIZE=4

FROM node:22-bookworm-slim AS builder

# Instalar dependencias de compilación
RUN apt-get update && apt-get install -y \
    python3 python3-pip make g++ \
    git curl wget \
    && rm -rf /var/lib/apt/lists/*

# Instalar pnpm globalmente
RUN npm install -g pnpm@10

WORKDIR /app

# Copiar monorepo
COPY . .

# Instalar dependencias
RUN pnpm install --frozen-lockfile || pnpm install

# Construir el API server
RUN pnpm --filter @workspace/api-server run build

# Construir la librería de DB también
RUN pnpm --filter @workspace/db run build

# Production stage
FROM node:22-bookworm-slim

# Instalar dependencias en runtime
RUN apt-get update && apt-get install -y \
    curl postgresql-client \
    && rm -rf /var/lib/apt/lists/*

# Instalar pnpm
RUN npm install -g pnpm@10

WORKDIR /app

# Copiar package files del monorepo
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY entrypoint-api.sh ./entrypoint-api.sh

# Copiar solo los archivos necesarios del builder
COPY --from=builder /app/artifacts/api-server ./artifacts/api-server
COPY --from=builder /app/lib ./lib
COPY --from=builder /app/tsconfig.base.json ./tsconfig.base.json

# Instalar solo dependencias de producción
RUN pnpm install --prod --frozen-lockfile || pnpm install --prod

# Crear directorios
RUN mkdir -p /root/projects /root/workspace

# Dar permisos al entrypoint
RUN chmod +x /app/entrypoint-api.sh

ENV HOME=/root
ENV NODE_ENV=production
PORT=3001

EXPOSE 3001

# Health check
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD curl -f http://localhost:3001/api/healthz || exit 1

ENTRYPOINT ["/app/entrypoint-api.sh"]
